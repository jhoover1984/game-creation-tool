{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcs.dev/schema/story.dialogueTruth.v2.json",
  "title": "Dialogue Truth V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "truthAtoms", "templates", "stylePacks"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "truthAtoms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["atomId", "pattern"],
        "properties": {
          "atomId": { "$ref": "common.v2.json#/$defs/Id" },
          "pattern": { "type": "string", "minLength": 3, "maxLength": 200 },
          "slots": {
            "type": "array",
            "items": { "type": "string", "maxLength": 40 }
          }
        }
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["templateId", "atomId", "baseText"],
        "properties": {
          "templateId": { "$ref": "common.v2.json#/$defs/Id" },
          "atomId": { "$ref": "common.v2.json#/$defs/Id" },
          "baseText": { "type": "string", "minLength": 3, "maxLength": 400 }
        }
      }
    },
    "stylePacks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["styleId", "name", "variants"],
        "properties": {
          "styleId": { "$ref": "common.v2.json#/$defs/Id" },
          "name": { "type": "string", "minLength": 1, "maxLength": 60 },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["templateId", "choices"],
              "properties": {
                "templateId": { "$ref": "common.v2.json#/$defs/Id" },
                "choices": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 3, "maxLength": 400 }
                }
              }
            }
          }
        }
      }
    }
  }
}
