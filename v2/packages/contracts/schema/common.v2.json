{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcs.dev/schema/common.v2.json",
  "title": "Common Types V2",
  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-z]+_[a-zA-Z0-9\\-_:]+$"
    },
    "SemVer": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "Vec2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "Vec3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "ResourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetId"],
      "properties": {
        "assetId": { "$ref": "#/$defs/Id" },
        "subId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    }
  }
}
