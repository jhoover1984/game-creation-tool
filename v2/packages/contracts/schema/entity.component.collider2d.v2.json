{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcs.dev/schema/entity.component.collider2d.v2.json",
  "title": "Collider2D Component V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "shape", "layer"],
  "properties": {
    "type": { "const": "Collider2D" },
    "layer": { "type": "string", "minLength": 1, "maxLength": 40 },
    "isTrigger": { "type": "boolean", "default": false },
    "shape": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "halfExtents"],
          "properties": {
            "kind": { "const": "box" },
            "halfExtents": { "$ref": "common.v2.json#/$defs/Vec2" },
            "offset": { "$ref": "common.v2.json#/$defs/Vec2" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "radius"],
          "properties": {
            "kind": { "const": "circle" },
            "radius": { "type": "number", "minimum": 0 },
            "offset": { "$ref": "common.v2.json#/$defs/Vec2" }
          }
        }
      ]
    }
  }
}
