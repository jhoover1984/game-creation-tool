{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcs.dev/schema/animation.clip.v2.json",
  "title": "AnimationClip V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assetId", "name", "fps", "frames", "anchors", "events"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "assetId": { "$ref": "common.v2.json#/$defs/Id" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "fps": {
      "type": "number",
      "minimum": 1,
      "maximum": 120,
      "x-ui": { "widget": "number", "step": 1 }
    },
    "loop": {
      "type": "boolean",
      "default": true,
      "x-ui": { "widget": "toggle" }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sprite", "duration"],
        "properties": {
          "sprite": { "$ref": "common.v2.json#/$defs/ResourceRef" },
          "duration": {
            "type": "number",
            "minimum": 0.001,
            "x-ui": { "widget": "number", "step": 0.001 }
          },
          "origin": { "$ref": "common.v2.json#/$defs/Vec2" },
          "occlusionMask": { "$ref": "common.v2.json#/$defs/ResourceRef" }
        }
      }
    },
    "anchors": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["frame", "pos"],
          "properties": {
            "frame": { "type": "integer", "minimum": 0 },
            "pos": { "$ref": "common.v2.json#/$defs/Vec2" },
            "rot": { "type": "number" },
            "flip": { "type": "boolean" }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["frame", "name"],
        "properties": {
          "frame": { "type": "integer", "minimum": 0 },
          "name": { "type": "string", "minLength": 1, "maxLength": 60 },
          "payload": {
            "type": "object",
            "additionalProperties": { "type": ["number", "string", "boolean"] }
          }
        }
      }
    }
  }
}
